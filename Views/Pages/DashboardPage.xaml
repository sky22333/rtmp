<Page x:Class="StreamCapturePro.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewmodels="clr-namespace:StreamCapturePro.ViewModels"
      xmlns:converters="clr-namespace:StreamCapturePro.Converters"
      d:DataContext="{d:DesignInstance Type=viewmodels:DashboardViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="700"
      Title="DashboardPage">

    <Page.Resources>
        <converters:BoolToStartStopConverter x:Key="BoolToStartStopConverter" />
        <converters:BoolToIconConverter x:Key="BoolToIconConverter" />
        <converters:BoolToAppearanceConverter x:Key="BoolToAppearanceConverter" />
    </Page.Resources>

    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <!-- 头部：标题与状态控制 -->
            <RowDefinition Height="Auto"/>
            <!-- 核心：推流信息卡片 -->
            <RowDefinition Height="Auto"/>
            <!-- 底部：目标进程配置 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. 头部控制区 -->
        <ui:Card Grid.Row="0" Padding="16,12" Margin="0,0,0,12" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="捕获状态" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{Binding StatusText, NotifyOnTargetUpdated=True}" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.4" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <ui:Button Grid.Column="1" 
                           Content="{Binding IsCapturing, Converter={StaticResource BoolToStartStopConverter}, Mode=OneWay}"
                           Icon="{Binding IsCapturing, Converter={StaticResource BoolToIconConverter}, Mode=OneWay}"
                           Appearance="{Binding IsCapturing, Converter={StaticResource BoolToAppearanceConverter}, Mode=OneWay}"
                           Command="{Binding StartCaptureCommand}"
                           Padding="20,8" FontSize="14" MinWidth="120"/>
            </Grid>
        </ui:Card>

        <!-- 2. 推流信息展示区 -->
        <ui:Card Grid.Row="1" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ui:SymbolIcon Symbol="Stream24" FontSize="18" Margin="0,0,8,0" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                    <TextBlock Text="推流详情" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="服务器" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:TextBox Grid.Column="1" Text="{Binding ServerAddress, Mode=OneWay}" IsReadOnly="True" Margin="0,0,8,0" Height="32"/>
                    <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Copy24}" Content="复制" Command="{Binding CopyServerCommand}" Appearance="Secondary" Height="32"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="串流密钥" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:TextBox Grid.Column="1" Text="{Binding StreamKey, Mode=OneWay}" IsReadOnly="True" Margin="0,0,8,0" Height="32"/>
                    <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Copy24}" Content="复制" Command="{Binding CopyKeyCommand}" Appearance="Secondary" Height="32"/>
                </Grid>

                <!-- OBS 同步控制 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="将捕获的推流码一键同步至本地 OBS Studio 的配置文件中。" 
                               FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon ArrowSync24}" Content="同步至 OBS" Command="{Binding SyncToObsCommand}" Appearance="Primary" Height="32"/>
                </Grid>
            </StackPanel>
        </ui:Card>

        <!-- 3. 配置区 -->
        <ui:Card Grid.Row="2" Padding="16,12" VerticalAlignment="Top">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="扫描目标配置" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                
                <ui:TextBox Text="{Binding ProcessKeywordsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=500}" 
                            PlaceholderText="例如：直播伴侣,kwailive" Height="32" Margin="0,0,0,6"/>
                <TextBlock Text="输入目标直播软件的进程关键字（多个用逗号分隔），可在任务管理器中查看进程名称。" 
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </ui:Card>

    </Grid>
</Page>
